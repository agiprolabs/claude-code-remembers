#!/usr/bin/env bash
set -euo pipefail

# claude-remembers — drop-in replacement for `claude` with active memory
#
# How it works:
#   1. Starts claude-memoryd daemon for the current project (if not running)
#   2. Queries daemon for compressed context → writes to MEMORY.md
#   3. Runs `claude` with all your arguments
#   4. After session ends, scans MEMORY.md for new entries → ingests into daemon
#
# This is a shim layer — it doesn't modify Claude Code internals.
# The daemon maintains the real memory store (SQLite). MEMORY.md becomes
# a sync point: daemon writes context into it before each session,
# and new entries written by Claude during the session get ingested back.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# --- Locate binaries ---

# claude-memoryd: check next to this script, then in release build dir, then PATH
if command -v claude-memoryd &>/dev/null; then
    MEMORYD_BIN="$(command -v claude-memoryd)"
elif [ -f "$SCRIPT_DIR/../target/release/claude-memoryd" ]; then
    MEMORYD_BIN="$SCRIPT_DIR/../target/release/claude-memoryd"
else
    echo "Error: claude-memoryd not found."
    echo "Build it: cd $(dirname "$SCRIPT_DIR") && cargo build --release"
    echo "Or add it to PATH."
    exit 1
fi

# claude: find the real claude binary
# If claude-remembers is installed as claude-remembers in the same dir as claude,
# make sure we don't recurse into ourselves
find_claude() {
    local self_path
    self_path="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"

    # Walk PATH entries to find `claude` that isn't us
    IFS=: read -ra path_dirs <<< "$PATH"
    for dir in "${path_dirs[@]}"; do
        local candidate="$dir/claude"
        if [ -x "$candidate" ] && [ "$(realpath "$candidate" 2>/dev/null)" != "$(realpath "$self_path" 2>/dev/null)" ]; then
            echo "$candidate"
            return
        fi
    done

    echo ""
}

CLAUDE_BIN=$(find_claude)
if [ -z "$CLAUDE_BIN" ]; then
    echo "Error: claude not found. Install Claude Code first:"
    echo "  npm install -g @anthropic-ai/claude-code"
    exit 1
fi

# --- Project paths ---

PROJECT_DIR="$(pwd)"

# Claude Code encodes project paths by replacing / with -
# /Volumes/Projects/myapp → -Volumes-Projects-myapp
ENCODED_PROJECT=$(echo "$PROJECT_DIR" | sed 's|/|-|g')
CLAUDE_PROJECT_DIR="$HOME/.claude/projects/$ENCODED_PROJECT"
MEMORY_FILE="$CLAUDE_PROJECT_DIR/memory/MEMORY.md"

# Daemon state directory
DAEMON_DIR="$CLAUDE_PROJECT_DIR/memoryd"
DB_PATH="$DAEMON_DIR/memory.db"
SOCK_PATH="$DAEMON_DIR/memoryd.sock"
PID_PATH="$DAEMON_DIR/memoryd.sock.pid"

# --- Daemon management ---

daemon_is_running() {
    if [ -f "$PID_PATH" ]; then
        local pid
        pid=$(cat "$PID_PATH")
        if kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
        # Stale pidfile
        rm -f "$PID_PATH" "$SOCK_PATH"
    fi
    return 1
}

start_daemon() {
    mkdir -p "$DAEMON_DIR"

    if daemon_is_running; then
        return 0
    fi

    "$MEMORYD_BIN" \
        --project "$PROJECT_DIR" \
        --db "$DB_PATH" \
        --socket "$SOCK_PATH" \
        &>/dev/null &

    # Wait for socket (up to 10 seconds)
    local attempts=0
    while [ $attempts -lt 40 ]; do
        if [ -S "$SOCK_PATH" ]; then
            return 0
        fi
        sleep 0.25
        attempts=$((attempts + 1))
    done

    echo "Warning: claude-memoryd failed to start, running without active memory" >&2
    return 1
}

send_ipc() {
    local msg="$1"
    echo "$msg" | nc -U "$SOCK_PATH" 2>/dev/null
}

# --- First-run migration ---

migrate_existing_memory() {
    # If MEMORY.md exists but daemon has no memories, do a one-time import
    if [ ! -f "$MEMORY_FILE" ]; then
        return 0
    fi

    # Check if daemon already has memories
    local status
    status=$(send_ipc '{"method":"get_status","params":null}' 2>/dev/null || true)
    local total
    total=$(echo "$status" | python3 -c "
import json, sys
try:
    r = json.load(sys.stdin)
    print(r.get('data', {}).get('total_memories', 0))
except:
    print(0)
" 2>/dev/null || echo "0")

    if [ "$total" != "0" ]; then
        return 0  # Already has memories, skip migration
    fi

    echo "Migrating existing MEMORY.md into active memory..." >&2
    local count=0
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        [[ "$line" =~ ^#.*$ ]] && continue
        [[ "$line" =~ ^---$ ]] && continue
        [[ "$line" =~ ^[[:space:]]*$ ]] && continue
        [[ "$line" =~ ^\> ]] && continue

        # Strip leading "- " from markdown lists
        line=$(echo "$line" | sed 's/^- //')
        [ ${#line} -lt 10 ] && continue

        local escaped
        escaped=$(printf '%s' "$line" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))' 2>/dev/null) || continue

        send_ipc "{\"method\":\"ingest\",\"params\":{\"content\":${escaped}}}" >/dev/null 2>&1
        count=$((count + 1))
    done < "$MEMORY_FILE"

    if [ "$count" -gt 0 ]; then
        echo "Migrated $count entries from MEMORY.md" >&2
    fi
}

# --- Memory sync ---

inject_context() {
    # Query daemon for compressed context and write to MEMORY.md
    if ! daemon_is_running; then
        return 1
    fi

    local response
    response=$(send_ipc '{"method":"get_context","params":{"max_tokens":1500}}')

    if [ -z "$response" ]; then
        return 1
    fi

    # Extract context from JSON response
    local context
    context=$(echo "$response" | python3 -c "
import json, sys
try:
    r = json.load(sys.stdin)
    if r.get('status') == 'ok':
        c = r['data']['context']
        if c and c.strip():
            print(c)
except:
    pass
" 2>/dev/null)

    if [ -n "$context" ]; then
        mkdir -p "$(dirname "$MEMORY_FILE")"
        echo "$context" > "$MEMORY_FILE"
    fi
}

snapshot_memory() {
    if [ -f "$MEMORY_FILE" ]; then
        cp "$MEMORY_FILE" "$DAEMON_DIR/.memory_snapshot"
    else
        touch "$DAEMON_DIR/.memory_snapshot"
    fi
}

ingest_new_entries() {
    # After session: diff MEMORY.md against snapshot, ingest new lines
    if ! daemon_is_running; then
        return 0
    fi

    if [ ! -f "$MEMORY_FILE" ] || [ ! -f "$DAEMON_DIR/.memory_snapshot" ]; then
        return 0
    fi

    # Find lines added during the session
    local new_lines
    new_lines=$(diff "$DAEMON_DIR/.memory_snapshot" "$MEMORY_FILE" 2>/dev/null | grep "^> " | sed 's/^> //' || true)

    if [ -z "$new_lines" ]; then
        return 0
    fi

    local count=0
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        [[ "$line" =~ ^#.*$ ]] && continue
        [[ "$line" =~ ^---$ ]] && continue
        [[ "$line" =~ ^[[:space:]]*$ ]] && continue
        [[ "$line" =~ ^\> ]] && continue

        # Strip leading "- "
        line=$(echo "$line" | sed 's/^- //')
        [ ${#line} -lt 10 ] && continue

        local escaped
        escaped=$(printf '%s' "$line" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))' 2>/dev/null) || continue

        send_ipc "{\"method\":\"ingest\",\"params\":{\"content\":${escaped}}}" >/dev/null 2>&1
        count=$((count + 1))
    done <<< "$new_lines"

    if [ "$count" -gt 0 ]; then
        send_ipc '{"method":"end_session","params":{"session_id":"'"$(date +%s)"'"}}' >/dev/null 2>&1
    fi

    rm -f "$DAEMON_DIR/.memory_snapshot"
}

# --- Main ---

main() {
    # Start daemon (silent, non-blocking)
    local daemon_ok=false
    if start_daemon; then
        daemon_ok=true
    fi

    if $daemon_ok; then
        # First run: migrate existing MEMORY.md
        migrate_existing_memory 2>/dev/null || true

        # Inject daemon context into MEMORY.md
        inject_context 2>/dev/null || true
        snapshot_memory 2>/dev/null || true
    fi

    # Run claude with all arguments passed through
    "$CLAUDE_BIN" "$@"
    local exit_code=$?

    # After session: ingest any new memory entries
    if $daemon_ok; then
        ingest_new_entries 2>/dev/null || true
    fi

    exit $exit_code
}

main "$@"
