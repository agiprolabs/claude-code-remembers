#!/usr/bin/env bash
set -euo pipefail

# claude-remembers — drop-in replacement for `claude` with active memory

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# --- Locate binaries ---

if command -v claude-memoryd &>/dev/null; then
    MEMORYD_BIN="$(command -v claude-memoryd)"
elif [ -f "$SCRIPT_DIR/../target/release/claude-memoryd" ]; then
    MEMORYD_BIN="$SCRIPT_DIR/../target/release/claude-memoryd"
else
    echo "Error: claude-memoryd not found. Build: cargo build --release" >&2
    exit 1
fi

find_claude() {
    local self_path
    self_path="$(realpath "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
    IFS=: read -ra path_dirs <<< "$PATH"
    for dir in "${path_dirs[@]}"; do
        local candidate="$dir/claude"
        if [ -x "$candidate" ] && [ "$(realpath "$candidate" 2>/dev/null)" != "$self_path" ]; then
            echo "$candidate"
            return
        fi
    done
}

CLAUDE_BIN=$(find_claude)
if [ -z "$CLAUDE_BIN" ]; then
    echo "Error: claude not found. Install Claude Code first." >&2
    exit 1
fi

# --- Project paths ---

PROJECT_DIR="$(pwd)"
ENCODED_PROJECT=$(echo "$PROJECT_DIR" | sed 's|/|-|g')
CLAUDE_PROJECT_DIR="$HOME/.claude/projects/$ENCODED_PROJECT"
MEMORY_FILE="$CLAUDE_PROJECT_DIR/memory/MEMORY.md"

DAEMON_DIR="$CLAUDE_PROJECT_DIR/memoryd"
DB_PATH="$DAEMON_DIR/memory.db"
SOCK_PATH="$DAEMON_DIR/memoryd.sock"
PID_PATH="$DAEMON_DIR/memoryd.pid"

# Temp file for IPC responses (avoids bash variable mangling JSON escapes)
IPC_TMP=$(mktemp)
trap 'rm -f "$IPC_TMP"' EXIT

# --- IPC ---

send_ipc() {
    echo "$1" | nc -w1 -U "$SOCK_PATH" > "$IPC_TMP" 2>/dev/null
}

# Parse a field from the JSON response in $IPC_TMP
parse_ipc() {
    python3 -c "
import json
with open('$IPC_TMP') as f:
    r = json.loads(f.read())
$1
" 2>/dev/null
}

# --- Daemon management ---

daemon_is_running() {
    if [ -f "$PID_PATH" ]; then
        kill -0 "$(cat "$PID_PATH")" 2>/dev/null && return 0
        rm -f "$PID_PATH" "$SOCK_PATH"
    fi
    return 1
}

start_daemon() {
    mkdir -p "$DAEMON_DIR"
    daemon_is_running && return 0

    # Clean up stale socket from previous run
    rm -f "$SOCK_PATH"

    "$MEMORYD_BIN" \
        --project "$PROJECT_DIR" \
        --db "$DB_PATH" \
        --socket "$SOCK_PATH" \
        &>/dev/null &

    local i=0
    while [ $i -lt 40 ]; do
        [ -S "$SOCK_PATH" ] && return 0
        sleep 0.25
        i=$((i + 1))
    done
    echo "Warning: claude-memoryd failed to start" >&2
    return 1
}

# --- First-run migration ---

migrate_existing_memory() {
    [ -f "$MEMORY_FILE" ] || return 0

    send_ipc '{"method":"get_status","params":null}'
    local total
    total=$(parse_ipc "
if r.get('status') == 'ok':
    print(r['data'].get('total_memories', 0))
else:
    print(0)
" || echo "0")

    [ "$total" != "0" ] && return 0

    echo "Migrating existing MEMORY.md into active memory..." >&2
    local count=0
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        [[ "$line" =~ ^[#\>\-\-\-] ]] && [[ "$line" =~ ^#|^---$|^\> ]] && continue
        [[ "$line" =~ ^[[:space:]]*$ ]] && continue

        line=$(echo "$line" | sed 's/^- //')
        [ ${#line} -lt 10 ] && continue

        local escaped
        escaped=$(printf '%s' "$line" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))') || continue
        send_ipc "{\"method\":\"ingest\",\"params\":{\"content\":${escaped}}}" >/dev/null
        count=$((count + 1))
    done < "$MEMORY_FILE"

    [ "$count" -gt 0 ] && echo "Migrated $count entries" >&2
}

# --- Memory sync ---

inject_context() {
    daemon_is_running || return 1

    send_ipc '{"method":"get_context","params":{"max_tokens":1500}}'

    mkdir -p "$(dirname "$MEMORY_FILE")"
    parse_ipc "
if r.get('status') == 'ok':
    c = r['data']['context']
    if c and c.strip():
        with open('$MEMORY_FILE', 'w') as f:
            f.write(c)
"
}

snapshot_memory() {
    if [ -f "$MEMORY_FILE" ]; then
        cp "$MEMORY_FILE" "$DAEMON_DIR/.memory_snapshot"
    else
        touch "$DAEMON_DIR/.memory_snapshot"
    fi
}

ingest_new_entries() {
    daemon_is_running || return 0
    [ -f "$MEMORY_FILE" ] && [ -f "$DAEMON_DIR/.memory_snapshot" ] || return 0

    local new_lines
    new_lines=$(diff "$DAEMON_DIR/.memory_snapshot" "$MEMORY_FILE" 2>/dev/null | grep "^> " | sed 's/^> //' || true)
    [ -z "$new_lines" ] && return 0

    local count=0
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        [[ "$line" =~ ^#|^---|^[[:space:]]*$|^\> ]] && continue

        line=$(echo "$line" | sed 's/^- //')
        [ ${#line} -lt 10 ] && continue

        local escaped
        escaped=$(printf '%s' "$line" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))') || continue
        send_ipc "{\"method\":\"ingest\",\"params\":{\"content\":${escaped}}}" >/dev/null
        count=$((count + 1))
    done <<< "$new_lines"

    [ "$count" -gt 0 ] && send_ipc '{"method":"end_session","params":{"session_id":"'"$(date +%s)"'"}}' >/dev/null
    rm -f "$DAEMON_DIR/.memory_snapshot"
}

# --- Main ---

main() {
    local daemon_ok=false
    start_daemon && daemon_ok=true

    if $daemon_ok; then
        migrate_existing_memory 2>/dev/null || true
        inject_context 2>/dev/null || true
        snapshot_memory 2>/dev/null || true
    fi

    "$CLAUDE_BIN" "$@"
    local exit_code=$?

    if $daemon_ok; then
        ingest_new_entries 2>/dev/null || true
    fi

    exit $exit_code
}

main "$@"
